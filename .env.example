# Active/Désactive l'envoi d'emails
SMTP_ENABLED=true

# Serveur SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# Authentification SMTP (laisser vide si votre serveur n'en demande pas)
SMTP_USER=votre_adresse@gmail.com
SMTP_PASSWORD=votre_mot_de_passe_app

# Expéditeur / destinataire
SMTP_FROM=votre_adresse@gmail.com
SMTP_TO=security-team@entreprise.com

# Notifier aussi les "refuse" (sinon seulement "imposteur")
SMTP_NOTIFY_REFUSE=true

# Anti-spam (en secondes) pour un même statut
SMTP_NOTIFY_COOLDOWN_SECONDS=30
